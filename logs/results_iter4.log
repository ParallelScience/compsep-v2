            y_np = y.cpu().numpy()
            
            R_np = y_np - pred_np
            
            for i in range(R_np.shape[0]):
                r = R_np[i]
                t = y_np[i]
                
                out1_r, out2_r = utils.powers(r, r, ps=1.17, window_alpha=0.5)
                if np.max(out1_r) > np.max(out2_r):
                    ell = out1_r
                    ps_r = out2_r
                else:
                    ell = out2_r
                    ps_r = out1_r
                    
                out1_t, out2_t = utils.powers(t, t, ps=1.17, window_alpha=0.5)
                if np.max(out1_t) > np.max(out2_t):
                    ps_t = out2_t
                else:
                    ps_t = out1_t
                    
                if ells is None:
