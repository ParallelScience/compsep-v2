                ps_R_list.append(ps_r)
                ps_T_list.append(ps_t)

    ps_R_arr = np.array(ps_R_list)
    ps_T_arr = np.array(ps_T_list)
    
    mean_ps_R = np.mean(ps_R_arr, axis=0)
    mean_ps_T = np.mean(ps_T_arr, axis=0)
    
