        ell, p_auto_t = utils.powers(true_map, true_map, ps=pixel_size_arcmin)
        _, p_cross_s = utils.powers(srdae_map, true_map, ps=pixel_size_arcmin)
        _, p_auto_s = utils.powers(srdae_map, srdae_map, ps=pixel_size_arcmin)
        _, p_cross_c = utils.powers(cilc_map, true_map, ps=pixel_size_arcmin)
        _, p_auto_c = utils.powers(cilc_map, cilc_map, ps=pixel_size_arcmin)
        
        if ell_bins is None:
            ell_bins = ell
            
        P_auto_true.append(p_auto_t)
        P_cross_srdae.append(p_cross_s)
        P_auto_srdae.append(p_auto_s)
        P_cross_cilc.append(p_cross_c)
        P_auto_cilc.append(p_auto_c)
        
    P_auto_true = np.array(P_auto_true)
    P_cross_srdae = np.array(P_cross_srdae)
    P_auto_srdae = np.array(P_auto_srdae)
    P_cross_cilc = np.array(P_cross_cilc)
    P_auto_cilc = np.array(P_auto_cilc)
    
    mean_P_auto_true = np.mean(P_auto_true, axis=0)
