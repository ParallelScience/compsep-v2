            y_pred = model(x).cpu().numpy()
            y = y.numpy()
            y_pred = y_pred * y_std + y_mean
            y = y * y_std + y_mean
            srdae_preds.append(y_pred)
            srdae_trues.append(y)
    srdae_preds = np.concatenate(srdae_preds, axis=0).squeeze(1)
