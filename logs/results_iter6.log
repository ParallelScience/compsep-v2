        p_cross_c = utils.powers(cilc_map, true_map, ps=pixel_size_arcmin)[power_idx]
        p_auto_c = utils.powers(cilc_map, cilc_map, ps=pixel_size_arcmin)[power_idx]
        if ell_bins is None:
