        if i_planck is None:
            i_planck = np.random.randint(100)
        obs = np.zeros((6, 256, 256), dtype=np.float32)
        for i, freq in enumerate(frequencies):
            if not pure_noise:
                signal = np.load(BASE + '/stacked_' + str(freq) + '.npy', mmap_mode='r')[p]
