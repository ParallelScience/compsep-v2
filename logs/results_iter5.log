                if freq == 353:
                    noise = raw * 1e6
                else:
                    noise = raw * 1e6 * utils.jysr2uk(freq)
            obs[i] = signal + noise
        tsz = np.load(BASE + '/tsz.npy', mmap_mode='r')[p]
        return torch.tensor(obs).unsqueeze(0), torch.tensor(tsz).unsqueeze(0).unsqueeze(0)

