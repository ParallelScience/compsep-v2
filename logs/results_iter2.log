        y = self.Y[idx]
        m = self.M[idx]
        if self.augment:
            if np.random.rand() > 0.5:
                x = np.flip(x, axis=-1)
                y = np.flip(y, axis=-1)
                m = np.flip(m, axis=-1)
            if np.random.rand() > 0.5:
                x = np.flip(x, axis=-2)
                y = np.flip(y, axis=-2)
