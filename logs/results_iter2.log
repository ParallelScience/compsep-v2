def apply_cilc(patches_dict, W):
    fft_n = np.stack([np.fft.fft2(patches_dict[90], norm='ortho'), np.fft.fft2(patches_dict[150], norm='ortho'), np.fft.fft2(patches_dict[217], norm='ortho')], axis=-1)
