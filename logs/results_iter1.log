**Code Explanation:**

The code implements the four loss components required for the Super-Resolution Denoising Autoencoder (SR-DAE) and combines them into a `CompositeLoss` module. 
1. **HaarWaveletLoss**: Performs a differentiable 1-level Haar wavelet decomposition using 2D convolutions with a stride of 2. It penalizes the L1 difference in the high-frequency subbands (LH, HL, HH), which correspond to the 1-5 arcmin scale range.
2. **PseudoClLoss**: Computes a differentiable 2D power spectrum using `torch.fft.fft2` after applying a Tukey apodization window. It penalizes the absolute difference between the predicted and target power spectra specifically for multipoles $\ell > 1000$.
3. **FluxLoss**: Enforces both global and local flux conservation. The global term minimizes the absolute difference of the total sum across the patch, while the local term applies a Gaussian blur (sigma=3.0) and computes the L1 loss to preserve pressure in the vicinity of individual clusters.
4. **CompositeLoss**: Combines the L1, Wavelet, Pseudo-Cl, and Flux losses using configurable weights ($\lambda_1, \lambda_2, \lambda_3, \lambda_4$).

Additionally, the code provides the training setup functions: `setup_training` initializes the AdamW optimizer and the OneCycleLR scheduler, `get_lambda4_schedule` generates the linear annealing schedule for the flux term weight, and `train_one_epoch` encapsulates the mixed-precision training loop for a single epoch. The main block tests all components, verifies the backward pass, and saves the lambda annealing schedule to `data/lambda_schedule.csv`.

**Python Code:**

```python
import os
import numpy as np
import pandas as pd
import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.cuda.amp import autocast, GradScaler

class HaarWaveletLoss(nn.Module):
    """
    Differentiable multi-resolution wavelet loss using Haar wavelets.
    Penalizes deviations in the high-frequency subbands (LH, HL, HH).
    """
    def __init__(self, device='cuda'):
        super().__init__()
        ll = torch.tensor([[1., 1.], [1., 1.]]) / 2.0
        lh = torch.tensor([[-1., 1.], [-1., 1.]]) / 2.0
        hl = torch.tensor([[-1., -1.], [1., 1.]]) / 2.0
        hh = torch.tensor([[1., -1.], [-1., 1.]]) / 2.0
        
        self.filters = torch.stack([ll, lh, hl, hh]).unsqueeze(1).to(device)
        
    def forward(self, pred, target):
        """
        Computes the L1 loss on the high-frequency wavelet coefficients.
        """
        pred_coeffs = F.conv2d(pred, self.filters, stride=2)
        target_coeffs = F.conv2d(target, self.filters, stride=2)
        
        loss = F.l1_loss(pred_coeffs[:, 1:], target_coeffs[:, 1:])
        return loss

class PseudoClLoss(nn.Module):
    """
    Differentiable Pseudo-Cl estimator.
    Computes the power spectrum and penalizes differences for ell > 1000.
    """
    def __init__(self, n_pixels=256, patch_size_deg=5.0, device='cuda'):
        super().__init__()
        self.n_pixels = n_pixels
        self.patch_size_rad = patch_size_deg * np.pi / 180.0
        self.pix_size_rad = self.patch_size_rad / n_pixels
        
        window = self._create_tukey_window(n_pixels, alpha=0.2).to(device)
        self.window = window.view(1, 1, n_pixels, n_pixels)
        
        freqs = torch.fft.fftfreq(n_pixels, d=self.pix_size_rad).to(device)
        kx, ky = torch.meshgrid(freqs, freqs, indexing='ij')
        k_rad = torch.sqrt(kx**2 + ky**2)
        self.ell = k_rad * 2 * np.pi
        
        self.ell_mask = (self.ell > 1000).unsqueeze(0).unsqueeze(0)
        
    def _create_tukey_window(self, n, alpha=0.2):
        w = torch.ones(n)
        n_taper = int(alpha * n / 2)
        x = torch.linspace(0, 1, n_taper)
        taper = 0.5 * (1 - torch.cos(np.pi * x))
        w[:n_taper] = taper
        w[-n_taper:] = torch.flip(taper, dims=[0])
        w2d = w.unsqueeze(0) * w.unsqueeze(1)
        return w2d
        
    def forward(self, pred, target):
        """
        Computes the L1 loss on the power spectrum for ell > 1000.
        """
        p_win = pred * self.window
        t_win = target * self.window
        
        p_fft = torch.fft.fft2(p_win)
        t_fft = torch.fft.fft2(t_win)
        
        p_ps = torch.abs(p_fft)**2
        t_ps = torch.abs(t_fft)**2
        
        p_ps = p_ps / (self.n_pixels**2)
        t_ps = t_ps / (self.n_pixels**2)
        
        diff = torch.abs(p_ps - t_ps) * self.ell_mask
        loss = diff.sum() / (self.ell_mask.sum() * pred.size(0) + 1e-8)
        return loss

class FluxLoss(nn.Module):
    """
    Flux conservation loss.
    Combines global sum conservation and local flux constraint using a Gaussian-weighted sum.
    """
    def __init__(self, kernel_size=15, sigma=3.0, device='cuda'):
        super().__init__()
        self.kernel_size = kernel_size
        x = torch.arange(kernel_size).float() - kernel_size // 2
        xx, yy = torch.meshgrid(x, x, indexing='ij')
        kernel = torch.exp(-(xx**2 + yy**2) / (2 * sigma**2))
        kernel = kernel / kernel.sum()
        self.kernel = kernel.view(1, 1, kernel_size, kernel_size).to(device)
        self.padding = kernel_size // 2
        
    def forward(self, pred, target):
        """
        Computes the global and local flux conservation loss.
        """
        global_loss = torch.abs(pred.sum(dim=(1,2,3)) - target.sum(dim=(1,2,3))).mean()
        
        p_blur = F.conv2d(pred, self.kernel, padding=self.padding)
        t_blur = F.conv2d(target, self.kernel, padding=self.padding)
        local_loss = F.l1_loss(p_blur, t_blur)
        
        return global_loss + local_loss

class CompositeLoss(nn.Module):
    """
    Composite loss function combining L1, Wavelet, Pseudo-Cl, and Flux losses.
    """
    def __init__(self, lambda1=1.0, lambda2=0.1, lambda3=0.01, lambda4=0.0, device='cuda'):
        super().__init__()
        self.lambda1 = lambda1
        self.lambda2 = lambda2
        self.lambda3 = lambda3
        self.lambda4 = lambda4
        
        self.l1 = nn.L1Loss()
        self.wavelet = HaarWaveletLoss(device=device)
        self.pseudo_cl = PseudoClLoss(device=device)
        self.flux = FluxLoss(device=device)
        
    def forward(self, pred, target):
        """
        Computes the total composite loss and returns individual components.
        """
        loss_l1 = self.l1(pred, target)
        loss_wav = self.wavelet(pred, target)
        loss_cl = self.pseudo_cl(pred, target)
        loss_flux = self.flux(pred, target)
        
        total_loss = (self.lambda1 * loss_l1 + 
                      self.lambda2 * loss_wav + 
                      self.lambda3 * loss_cl + 
                      self.lambda4 * loss_flux)
                      
        return total_loss, loss_l1, loss_wav, loss_cl, loss_flux

def setup_training(model, train_loader, epochs=50, lr=1e-3):
    """
    Sets up the AdamW optimizer and OneCycleLR scheduler.
    """
    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-4)
    steps_per_epoch = len(train_loader)
    scheduler = torch.optim.lr_scheduler.OneCycleLR(
        optimizer, 
        max_lr=lr, 
        epochs=epochs, 
        steps_per_epoch=steps_per_epoch,
        pct_start=0.3,
        anneal_strategy='cos'
    )
    return optimizer, scheduler

def get_lambda4_schedule(epochs=50, start_epoch=10, end_epoch=30, max_val=0.1):
    """
    Generates the lambda annealing schedule for the flux term.
    """
    schedule = []
    for epoch in range(epochs):
        if epoch < start_epoch:
            val = 0.0
        elif epoch >= end_epoch:
            val = max_val
        else:
            val = max_val * (epoch - start_epoch) / float(end_epoch - start_epoch)
        schedule.append(val)
    return schedule

